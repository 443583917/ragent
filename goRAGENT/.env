# ============================================================
# goRAGENT 环境变量配置
# ============================================================

# --- App ---
APP_NAME=goRAGENT
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=9090

# --- MySQL (Docker 对外端口 3307) ---
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=ragent
MYSQL_POOL_SIZE=10
MYSQL_ECHO=false

# --- Milvus (Docker 对外端口 19532, 避免和 CarAgent embedding 19531 冲突) ---
MILVUS_HOST=localhost
MILVUS_PORT=19532
MILVUS_COLLECTION_NAME=ragent_knowledge

# --- Embedding HTTP 服务 (本地 BGE-M3) ---
EMBEDDING_HTTP_URL=http://localhost:19531
RERANK_HTTP_URL=http://localhost:19531

# --- LLM: Model Factory ---
# 可选: openai / deepseek / qwen / glm
LLM_PROVIDER=glm

# --- LLM 通用参数 ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# --- OpenAI (Mimo) ---
OPENAI_API_KEY=sk-ct6ct1y17ry3m9xh2rce3bbx68kbsqs19y326ym89hxw2k64
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2.5

# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-9b4805e2120c4ecabe0424f910f2333e
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Qwen (通义千问) ---
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- GLM (智谱) ---
GLM_API_KEY=5c28d550421042b3b92b9a59fd3f04dc.dZKMjNGVBEMPQXJz
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# --- Reranker ---
RERANKER_MODEL=BGE-M3
RERANKER_DEVICE=cpu

# --- RAG ---
RAG_TOP_K=10
RAG_RERANK_TOP_K=5
RAG_QUERY_REWRITE_ENABLED=true
RAG_RERANK_ENABLED=true

